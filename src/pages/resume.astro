---
import Base from "@/layouts/Base.astro";
---

<Base title="Resume" description="Resume for Zihao Fu.">
  <section class="section">
    <div class="container">
      <h1 class="h2 mb-8">Resume</h1>
      <div class="mb-4 flex flex-wrap gap-3">
        <a href="/assets/resume/Resume.html" target="_blank" rel="noopener" class="btn btn-primary">Open in new tab</a>
        <a href="/assets/resume/Resume.pdf" download="Zihao_Fu_Resume.pdf" class="btn border border-border">Download</a>
      </div>
      <iframe
        id="resume-iframe"
        src="/assets/resume/Resume.html"
        width="100%"
        height="1000"
        style="border:0;"
        title="Resume"
      />
    </div>
  </section>
</Base>
